HOST=127.0.0.1
PORT=5000
CLIENT_URL=http://localhost:5173
# Local Mongo example:
MONGODB_URI=mongodb://127.0.0.1:27017/typeform-clone

# Atlas non-SRV example:
# Leave MONGODB_URI empty and fill the values below with the standard
# connection string details copied from Atlas.
# MONGODB_URI=
# MONGODB_USERNAME=your-username
# MONGODB_PASSWORD=your-password
# MONGODB_HOSTS=ac-xxxx-shard-00-00.xxxxx.mongodb.net:27017,ac-xxxx-shard-00-01.xxxxx.mongodb.net:27017,ac-xxxx-shard-00-02.xxxxx.mongodb.net:27017
# MONGODB_DATABASE=typeform-clone
# MONGODB_OPTIONS=ssl=true&replicaSet=atlas-abc123-shard-0&authSource=admin&retryWrites=true&w=majority
JWT_SECRET=change-this-to-a-long-random-secret
GROQ_API_KEY=
